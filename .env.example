# Copy to .env and fill in (NEVER commit .env)

# ── Environment ──────────────────────────────────────────────────────────────
TRUTHNET_ENV=development
# production | development
FRONTEND_URL=http://127.0.0.1:8000

# ── Auth & database ──────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string
# Required in production (TRUTHNET_ENV=production)
AUTH_REQUIRED=false
# true in production — fact-check routes require login
DATABASE_URL=sqlite:///./truthnet.db
# Production: postgresql://user:pass@host:5432/truthnet

QUOTA_ENFORCE=true
BILLING_MODE=manual
# manual = preview tier selection without payment; stripe = require Checkout (Phase 2)
# Set false to disable tier limits (demo / guest still exempt when DEMO_MODE=true)

# ── Stripe (Phase 2 — set BILLING_MODE=stripe when ready) ───────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=
# Webhook endpoint: https://your-domain/webhooks/stripe

RATE_LIMIT_PER_MINUTE=10

# ── TruthNet pipeline ────────────────────────────────────────────────────────
TRUTHNET_MOCK=1
DEMO_MODE=true
# Set DEMO_MODE=false and TRUTHNET_MOCK=0 for live Gemini in production

TRUTHNET_AGENT_TIMEOUT=10
TRUTHNET_PIPELINE_TIMEOUT=28
TRUTHNET_TIMEOUT_A=10
TRUTHNET_TIMEOUT_BC=10
TRUTHNET_TIMEOUT_D=10

# ── Gemini 3 (production LLM stack) ─────────────────────────────────────────
AGENT_A_PROVIDER=gemini
AGENT_B_PROVIDER=gemini
AGENT_C_PROVIDER=gemini
AGENT_D_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_AGENT_A_API_KEY=
GEMINI_AGENT_B_API_KEY=
GEMINI_AGENT_C_API_KEY=
GEMINI_AGENT_D_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MAX_TOKENS=1000
GEMINI_AGENT_D_MAX_TOKENS=1400
GEMINI_USE_GOOGLE_SEARCH=true

# Google Fact Check (agents B/C pre-search)
GOOGLE_API_KEY=
GOOGLE_FACT_CHECK_API_KEY=

# ── Optional Anthropic fallback ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_AGENT_A_API_KEY=
ANTHROPIC_AGENT_BC_API_KEY=
ANTHROPIC_AGENT_D_API_KEY=

# ── Legacy starter-kit keys (unused by TruthNet core) ─────────────────────────
OPENAI_API_KEY=
HF_TOKEN=
REPLICATE_API_TOKEN=
