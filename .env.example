# Copy to .env and fill in (NEVER commit .env)

# Starter-kit keys
OPENAI_API_KEY=
HF_TOKEN=
REPLICATE_API_TOKEN=
OPENAI_MODEL=gpt-4o

# TruthNet providers
ANTHROPIC_AGENT_A_API_KEY=
ANTHROPIC_AGENT_D_API_KEY=
ANTHROPIC_AGENT_BC_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_FACT_CHECK_API_KEY=

AGENT_A_PROVIDER=anthropic
AGENT_B_PROVIDER=anthropic
AGENT_C_PROVIDER=anthropic
AGENT_D_PROVIDER=anthropic

GEMINI_API_KEY=
GEMINI_AGENT_A_API_KEY=
GEMINI_AGENT_B_API_KEY=
GEMINI_AGENT_C_API_KEY=
GEMINI_AGENT_D_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=800
GEMINI_AGENT_D_MAX_TOKENS=1400
GEMINI_USE_GOOGLE_SEARCH=false

ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_AGENT_A_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_AGENT_B_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_AGENT_C_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_AGENT_D_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=900
ANTHROPIC_AGENT_D_MAX_TOKENS=1200
ANTHROPIC_RATE_LIMIT_RETRIES=1
ANTHROPIC_RATE_LIMIT_WAIT_SECONDS=20
ANTHROPIC_DISABLE_WEB_SEARCH=false

TRUTHNET_MOCK=0
TRUTHNET_TIMEOUT_A=8
TRUTHNET_TIMEOUT_BC=16
TRUTHNET_TIMEOUT_D=30
